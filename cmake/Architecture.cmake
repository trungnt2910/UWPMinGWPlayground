if(CMAKE_HOST_SYSTEM_PROCESSOR MATCHES "x86_64|AMD64")
    set(UWP_HOST_SDK_ARCH "x64")
elseif(CMAKE_HOST_SYSTEM_PROCESSOR MATCHES "i686|x86")
    set(UWP_HOST_SDK_ARCH "x86")
elseif(CMAKE_HOST_SYSTEM_PROCESSOR MATCHES "aarch64|ARM64")
    set(UWP_HOST_SDK_ARCH "ARM64")
elseif(CMAKE_HOST_SYSTEM_PROCESSOR MATCHES "armv7|ARM")
    set(UWP_HOST_SDK_ARCH "ARM")
else()
    # Safe fallback.
    set(UWP_HOST_SDK_ARCH "x86")
endif()

if(CMAKE_SYSTEM_PROCESSOR MATCHES "x86_64|AMD64")
    set(UWP_SDK_ARCH "x64")
elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "i686|x86")
    set(UWP_SDK_ARCH "x86")
elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64|ARM64")
    set(UWP_SDK_ARCH "ARM64")
elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "armv7|ARM")
    set(UWP_SDK_ARCH "ARM")
endif()

string(TOLOWER ${UWP_SDK_ARCH} UWP_APPX_ARCH)
